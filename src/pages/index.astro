---
import Layout from '../layouts/Layout.astro';
import '../styles/anthropic.css';
import Globe from '../components/Globe.astro';

const capabilities = [
  { n: '01', title: 'Strategy', desc: 'Commercial strategy, GTM motion selection.' },
  { n: '02', title: 'GTM Execution', desc: 'Go-to-market execution across sales-led, product-led, partnership-led, marketing-led, and event-led motions.' },
  { n: '03', title: 'RevOps', desc: 'Pipeline architecture, tech stack optimisation, and full-funnel revenue engine design.' },
  { n: '04', title: 'Marketing', desc: 'Demand generation, ABM, messaging framework, and campaign execution.' },
  { n: '05', title: 'Sales', desc: 'Pipeline development and high-performance sales team building.' },
  { n: '06', title: 'Brand', desc: 'Segmentation, targeting, positioning, for B2B audiences.' },
  { n: '07', title: 'Board Advisory & Consulting', desc: 'Strategic counsel for founders on revenue, growth, and investor readiness.' },
];

const comparison = [
  { area: 'Track record in high-growth environments', others: 'General experience, limited verifiable metrics', tino: '~55% CAGR × 10yrs — one company, one sustained run' },
  { area: 'Serial founder & operator', others: 'Advisory in title, limited accountability', tino: 'Founded multiple businesses' },
  { area: 'ASX-listed & VC-backed company experience', others: 'Some exposure to funded companies', tino: 'Full journey: startup through to $460m ASX listing at OFX' },
  { area: 'Advisor & board member to founder-led businesses', others: 'Advisory in title, limited accountability', tino: 'Strategic counsel at board level, investor-ready positioning' },
  { area: 'Strategy through to execution', others: 'Decks and frameworks, limited hands-on delivery', tino: 'Not just decks — real outcomes, embedded operator' },
  { area: 'AI-first mindset.', others: 'AI tools mentioned, rarely deployed in production', tino: 'Builds with agentic AI and workflow automation — live systems in production' },
  { area: 'GTM stack experience', others: 'Basic CRM, occasional outbound', tino: 'CRM, B2B data & intelligence, sales engagement — fluent across the modern stack' },
];

const logos = [
  { src: 'https://tino-ho.github.io/site-scripts/OFX_idITLNbLii_0.png', alt: 'OFX' },
  { src: 'https://tino-ho.github.io/site-scripts/id4Q_YkH-m_logos%20(1).png', alt: 'Safetrac' },
  { src: 'https://tino-ho.github.io/site-scripts/Aware_Super_idMKzlcBsE_0.png', alt: 'Aware Super' },
  { src: "https://tino-ho.github.io/site-scripts/St-_James's_Place_Asia___Middle_East_idg0XeklVp_0.png", alt: 'St James Place' },
  { src: 'https://tino-ho.github.io/site-scripts/InterSystems_idZ7gLFrLi_0.png', alt: 'InterSystems' },
  { src: 'https://tino-ho.github.io/site-scripts/Tyro_idi6NsN6dj_0.svg', alt: 'Tyro' },
];

const releases = [
  {
    title: 'Fractional CRO for a Series A SaaS platform',
    desc: 'Pipeline architecture, GTM rebuild, and AI-powered SDR systems for a vertical SaaS founder team scaling into the US market.',
    date: 'June 2, 2026',
    category: 'Engagement',
  },
  {
    title: 'AI-native outbound engine for B2B founders',
    desc: 'A Claude + Apollo + n8n stack that personalises 500+ outreach touches/week. Built once, runs continuously, costs less than one SDR.',
    date: 'May 28, 2026',
    category: 'Case study',
  },
  {
    title: 'Board-level GTM counsel for founder-led businesses',
    desc: 'Quarterly strategic counsel on revenue, growth, and investor-readiness positioning. For pre-Series-A through to ASX listing.',
    date: 'March 11, 2026',
    category: 'Advisory',
  },
];

// Testimonials from tinoho.com, surfaced one at a time with typewriter
const testimonials = [
  {
    quote: "Tino is a well-rounded leader with a keen ability to navigate go-to-market complexities and translate sophisticated client needs into tangible, results-oriented outcomes. He consistently delivered innovative solutions, particularly in the areas of ESG and AI.",
    name: 'Michael Go',
    role: 'Chair & Non-Executive Director',
  },
  {
    quote: "Tino was a great asset to OzForex. He spent 10 years playing an important part in the growth of the business from a small start up to an ASX listed, market leading international payments specialist.",
    name: 'Jeff Parker',
    role: 'CEO Paymentology | Former CEO OzForex',
  },
  {
    quote: "Tino has demonstrated a remarkable ability to devise growth strategies and guide marketing and sales endeavours. If you're seeking a strategic independent advisor who excels in fostering growth — Tino is an excellent choice.",
    name: 'Julie Manios',
    role: 'Proptech Executive Director',
  },
  {
    quote: "I had the pleasure of working with Tino for five years at OFX. He is diligent, productive and responsive. Tino set up the BDM function at OFX and helped to deliver consistent year on year growth.",
    name: 'Christopher Minehan',
    role: 'Former OFX CMO, Founder ClickedOn',
  },
  {
    quote: "I enjoyed working with Tino who was professional and diligent throughout the engagement. He exhibits genuine passion for his work which gave me the confidence to engage him and his team.",
    name: 'Tim Beard',
    role: 'Chief Commercial Officer, Silverbullet',
  },
  {
    quote: "Tino served as our CRO and his leadership was exceptional, showing a strong commitment not only to increasing the company's revenue but also to fostering my professional growth within the business and beyond.",
    name: 'Ben Zylbersztajn',
    role: 'Senior BDM, Safetrac',
  },
];

// Sector chips that cycle on the globe
const sectors = ['Fintech', 'ESG', 'EdTech', 'GRC'];

const footerCols = [
  {
    title: 'Capabilities',
    links: [
      { label: 'Strategy', href: '#capabilities' },
      { label: 'GTM Execution', href: '#capabilities' },
      { label: 'RevOps', href: '#capabilities' },
      { label: 'Marketing', href: '#capabilities' },
      { label: 'Sales', href: '#capabilities' },
      { label: 'Brand', href: '#capabilities' },
      { label: 'Board Advisory & Consulting', href: '#capabilities' },
      { label: 'AI & Automation', href: '#capabilities' },
    ],
  },
  {
    title: 'About',
    links: [
      { label: 'Tino Ho', href: '#about' },
      { label: 'Results', href: '#results' },
      { label: 'Testimonials', href: '#testimonials' },
      { label: 'Why Tino', href: '#compare' },
    ],
  },
  {
    title: 'Connect',
    links: [
      { label: 'LinkedIn', href: 'https://www.linkedin.com/in/tinoho/' },
    ],
  },
];
---

<Layout title="Tino Ho">

  <!-- TOP BRAND STRIP -->
  <div class="an-top-strip"></div>

  <!-- NAV -->
  <nav class="an-nav">
    <div class="an-container">
      <div class="an-nav-inner">
        <span class="an-logo">TINO HO</span>
        <div class="an-nav-links">
          <a href="#capabilities">Capabilities</a>
          <a href="#compare">Why Tino</a>
          <a href="#testimonials">Testimonials</a>
          <a href="#about">About</a>
          <a href="#contact" class="an-nav-cta">Work with Tino</a>
        </div>
        <button class="an-ham" id="anHamBtn" aria-label="Open menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="an-hero">
    <div class="an-container">
      <div class="an-hero-grid">
        <h1 class="an-hero-headline">
          I lead and scale <span class="accent">B2B software</span> businesses.
        </h1>
        <div class="an-hero-side"></div>
      </div>
    </div>
  </section>

  <!-- FEATURED PANEL -->
  <section>
    <div class="an-container">
      <div class="an-feature">
        <div style="position:absolute; left:50%; top:44%; transform:translate(-50%,-38%); z-index:0;">
          <Globe />
        </div>

        <h2 class="an-feature-headline">I'm a hands-on commercial leader and go-to-market operator.</h2>

        <!-- Sector chip + carousel dots + bio blurb — pinned to bottom of box via CSS -->
        <div class="an-feature-globe-italy">
          <div class="an-feature-italy-dots" id="globe-dots">
            {sectors.map((_, i) => (
              <span class={i === 0 ? 'active' : ''}></span>
            ))}
          </div>
          <div><span class="an-feature-italy-chip" id="globe-chip">{sectors[0]}</span></div>
          <p class="an-feature-bio">
            20+ years running SaaS and technology enabled businesses between $3m and $50m ARR across APAC, from VC-backed early stage through to an ASX listing.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- LOGOS -->
  <section class="an-logos">
    <div class="an-container">
      <p class="an-logos-label">Some of the companies Tino has worked for and customers served</p>
      <div class="an-logos-row">
        {logos.map((logo) => (
          <img src={logo.src} alt={logo.alt} loading="lazy" onerror="this.style.display='none'" />
        ))}
      </div>
    </div>
  </section>

  <!-- CAPABILITIES — One full revenue stack. Seven capabilities. -->
  <section class="an-caps" id="capabilities">
    <div class="an-container">
      <div class="an-caps-wrap">
        <div class="an-caps-left">
          <h2 class="an-caps-headline">One full revenue stack. Seven capabilities.</h2>
          <p class="an-caps-sub">Each capability is a component of one integrated revenue system — designed to work together, built to scale.</p>
          <a href="#contact" class="an-btn an-btn-dark">Work with Tino →</a>
        </div>
        <div class="an-caps-grid">
          {capabilities.map((cap) => (
            <div class="an-cap-card">
              <div class="an-cap-n">{cap.n}</div>
              <div class="an-cap-t">{cap.title}</div>
              <p class="an-cap-d">{cap.desc}</p>
            </div>
          ))}
          <div class="an-cap-card an-cap-empty"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPARISON — What makes Tino different? -->
  <section class="an-compare" id="compare">
    <div class="an-container">
      <h2 class="an-compare-headline">What makes Tino different?</h2>
      <p class="an-compare-sub">A unique combination across several areas.</p>
      <div class="an-compare-wrap">
        <table class="an-compare-table">
          <thead>
            <tr>
              <th>Area</th>
              <th>Others</th>
              <th class="an-col-tino" style="color: var(--accent) !important;">Tino Ho</th>
            </tr>
          </thead>
          <tbody>
            {comparison.map((row, i) => (
              <tr>
                <td>{row.area}</td>
                <td class="an-col-other an-col-cross"><span class="an-cmp-x">✕</span></td>
                <td class="an-col-tino"><span class="an-cmp-check" style={`animation-delay:${i * 0.3}s`}>✓</span> {row.tino}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS — typewriter, cycles through quotes -->
  <section class="an-testi" id="testimonials">
    <div class="an-container">
      <div class="an-section-eyebrow">What others say</div>
      <div class="an-testi-stage">
        <p class="an-testi-quote">
          <span id="testi-text"></span><span class="an-testi-caret" aria-hidden="true"></span>
        </p>
        <div class="an-testi-author" id="testi-author">
          <div class="an-testi-name" id="testi-name"></div>
          <div class="an-testi-role" id="testi-role"></div>
        </div>
        <div class="an-testi-progress" id="testi-progress">
          {testimonials.map((_, i) => (
            <span class={i === 0 ? 'active' : ''}></span>
          ))}
        </div>
      </div>
      <!-- Data island the script reads -->
      <script type="application/json" id="testi-data" set:html={JSON.stringify(testimonials)}></script>
    </div>
  </section>

  <!-- DARK MISSION SECTION -->
  <section class="an-mission" id="about">
    <div class="an-container">
      <div class="an-mission-grid an-mission-grid--single" id="contact">
        <div class="an-mission-right">
          <h2 class="an-mission-headline">Are you ready for Tino to be part of your team?</h2>
          <div class="an-mission-body">
            <p>
              Held chief revenue officer, managing director, board and founder roles, leading cross-functional teams of up to 35 FTE across sales, customer success, account management and revenue operations.
            </p>
            <a href="#contact" class="an-btn an-btn-ivory">Get in touch</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="an-footer">
    <div class="an-container">
      <div class="an-footer-grid">
        <div class="an-footer-col">
          <div style="font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(250, 249, 245, 0.5); padding-top: 4px;">Tino Ho · Sydney, AU</div>
        </div>
        {footerCols.map((col) => (
          <div class="an-footer-col">
            <div class="an-footer-col-title">{col.title}</div>
            <ul>
              {col.links.map((l) => (
                <li><a href={l.href}>{l.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div class="an-footer-bottom">
        <span>© 2026 Tino Ho</span>
        <span>Acknowledging the Gadigal people of the Eora Nation</span>
      </div>
    </div>
  </footer>

  <script>
    import createGlobe from 'cobe';

    /* ─────────── COBE GLOBE ─────────── */
    // APAC markers — Sydney highlighted, cluster across AU/SEA/Japan
    const markers = [
      { location: [-33.8688,  151.2093], size: 0.10 }, // Sydney (primary)
      { location: [-37.8136,  144.9631], size: 0.07 }, // Melbourne
      { location: [  1.3521,  103.8198], size: 0.07 }, // Singapore
      { location: [ 35.6762,  139.6503], size: 0.07 }, // Tokyo
      { location: [ 22.3193,  114.1694], size: 0.06 }, // Hong Kong
      { location: [-36.8485,  174.7633], size: 0.05 }, // Auckland
    ];

    // phi for APAC centre — ~151° E = Sydney longitude in radians
    const APAC_PHI = -(151.2 * Math.PI / 180);

    const canvas = document.getElementById('globe-canvas') as HTMLCanvasElement | null;
    if (canvas) {
      let phi = APAC_PHI;
      let width = 0;
      const onResize = () => {
        width = canvas.offsetWidth;
        // keep canvas square
        canvas.style.height = canvas.offsetWidth + 'px';
      };
      window.addEventListener('resize', onResize);
      onResize();

      createGlobe(canvas, {
        devicePixelRatio: 2,
        width: width * 2,
        height: width * 2,
        phi: APAC_PHI,
        theta: -0.28,             // tilt down toward southern hemisphere (Australia)
        dark: 0,
        diffuse: 1.0,
        mapSamples: 24000,        // more samples = finer dot map
        mapBrightness: 3.5,       // lighter dots to match reference
        baseColor: [0.941, 0.933, 0.898],  // ivory-medium #f0eee6
        markerColor: [212/255, 162/255, 127/255],  // kraft #d4a27f
        glowColor:  [0.941, 0.933, 0.898],
        opacity: 0.92,
        markers,
        onRender: (state) => {
          state.phi = phi;
          phi += 0.0015;          // slow drift — APAC stays centred longer
          state.width  = width * 2;
          state.height = width * 2;
        },
      });
    }

    /* ─────────── CYCLING SECTOR CHIP ─────────── */
    const sectorNames = ['Fintech', 'ESG', 'EdTech', 'GRC'];
    const chip = document.getElementById('globe-chip');
    const dotsEl = document.getElementById('globe-dots');
    if (chip && dotsEl) {
      const dots = Array.from(dotsEl.querySelectorAll('span'));
      let idx = 0;
      setInterval(() => {
        idx = (idx + 1) % sectorNames.length;
        chip.textContent = sectorNames[idx];
        dots.forEach((d, i) => d.classList.toggle('active', i === idx));
      }, 3000);
    }

    /* ─────────── TYPEWRITER TESTIMONIALS ─────────── */
    const dataEl = document.getElementById('testi-data');
    const textEl = document.getElementById('testi-text');
    const nameEl = document.getElementById('testi-name');
    const roleEl = document.getElementById('testi-role');
    const authorEl = document.getElementById('testi-author');
    const progressEl = document.getElementById('testi-progress');

    if (dataEl && textEl && nameEl && roleEl && authorEl && progressEl) {
      const items: { quote: string; name: string; role: string }[] = JSON.parse(dataEl.textContent || '[]');
      const progressDots = Array.from(progressEl.querySelectorAll('span'));
      const wait = (ms: number) => new Promise(r => setTimeout(r, ms));

      const typeText = async (el: HTMLElement, text: string, speed = 22) => {
        el.textContent = '';
        for (let i = 0; i < text.length; i++) {
          el.textContent = text.slice(0, i + 1);
          // pause longer on punctuation for natural rhythm
          const ch = text[i];
          const pause = ch === '.' || ch === '!' || ch === '?' ? speed * 6
                      : ch === ',' || ch === ';'              ? speed * 3
                      : speed;
          await wait(pause);
        }
      };

      const fadeOut = (el: HTMLElement) => { el.style.opacity = '0'; };
      const fadeIn  = (el: HTMLElement) => { el.style.opacity = '1'; };

      const runLoop = async () => {
        let i = 0;
        while (true) {
          progressDots.forEach((d, j) => d.classList.toggle('active', j === i));
          fadeOut(authorEl);
          await typeText(textEl, items[i].quote);
          nameEl.textContent = items[i].name;
          roleEl.textContent = items[i].role;
          fadeIn(authorEl);
          await wait(4500);
          fadeOut(authorEl);
          await wait(400);
          // erase backwards
          for (let n = items[i].quote.length; n >= 0; n -= 4) {
            textEl.textContent = items[i].quote.slice(0, n);
            await wait(8);
          }
          i = (i + 1) % items.length;
        }
      };

      // start on next tick so layout settles
      requestAnimationFrame(() => runLoop());
    }

    /* ─────────── MOBILE NAV ─────────── */
    const anHam = document.getElementById('anHamBtn');
    anHam?.addEventListener('click', () => {
      document.querySelector('.an-nav-links')?.classList.toggle('is-open');
    });
  </script>

</Layout>
